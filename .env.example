# Database
PGDATABASE_URL=postgresql://user:password@localhost:5432/database

# WeChat payment
WECHAT_APPID=your_wechat_appid
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_API_KEY=your_wechat_api_key
WECHAT_NOTIFY_URL=https://yugioh.top/api/payment/wechat/jsapi/callback

# WeChat official account
WECHAT_MP_APPID=your_wechat_mp_appid
WECHAT_MP_SECRET=your_wechat_mp_secret

# App URLs
NEXT_PUBLIC_BASE_URL=https://yugioh.top
NEXT_PUBLIC_SOCKET_URL=https://yugioh.top:3001
NEXT_PUBLIC_APP_URL=https://yugioh.top

# WeChat CloudRun storage
# Production runtime should use the official WeChat CloudRun storage API with env id only.
CLOUDBASE_ENV_ID=your-cloudrun-env-id
# Or use the CloudRun-provided env variable name directly:
# CBR_ENV_ID=your-cloudrun-env-id
#
# Local debugging and self-check need WECHAT_MP_APPID / WECHAT_MP_SECRET to fetch access_token.
# If you want to allow local fallback writes into public/uploads when cloud storage is unavailable:
# ALLOW_LOCAL_STORAGE_UPLOADS=true
