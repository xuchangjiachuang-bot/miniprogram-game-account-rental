# 数据库配置
PGDATABASE_URL=postgresql://user:password@localhost:5432/database

# 微信支付配置
WECHAT_APPID=your_wechat_appid
WECHAT_MCH_ID=your_wechat_mch_id
WECHAT_API_KEY=your_wechat_api_key
WECHAT_NOTIFY_URL=https://yugioh.top/api/payment/wechat/jsapi/callback

# 微信公众号配置
WECHAT_MP_APPID=your_wechat_mp_appid
WECHAT_MP_SECRET=your_wechat_mp_secret

# 应用配置
NEXT_PUBLIC_BASE_URL=https://yugioh.top
NEXT_PUBLIC_SOCKET_URL=https://yugioh.top:3001
NEXT_PUBLIC_APP_URL=https://yugioh.top

# 对象存储配置（如果使用）
# COZE_BUCKET_ENDPOINT_URL=https://your-bucket-endpoint
# COZE_BUCKET_NAME=your-bucket-name
# ALLOW_LOCAL_STORAGE_UPLOADS=true
