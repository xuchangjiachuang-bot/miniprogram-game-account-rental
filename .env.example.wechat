# 微信支付配置
# 请替换为你的实际配置

# 微信支付商户号配置
WECHAT_PAY_MCHID=your_mchid_here
WECHAT_PAY_SERIAL_NO=your_serial_no_here
WECHAT_PAY_PRIVATE_KEY=your_private_key_here
WECHAT_PAY_APIV3_PRIVATE_KEY=your_apiv3_private_key_here

# 微信公众号/小程序配置
WECHAT_PAY_APPID=your_appid_here
WECHAT_PAY_APPSECRET=your_appsecret_here

# 支付回调地址
WECHAT_PAY_NOTIFY_URL=https://yourdomain.com/api/payment/wechat/notify

# 转账接口配置
WECHAT_TRANSFER_NOTIFY_URL=https://yourdomain.com/api/transfer/wechat/notify
