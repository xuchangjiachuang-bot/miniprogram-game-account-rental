# ========================================
# 生产环境配置模板
# ========================================
# 使用方法：
# 1. 复制此文件为 .env.production
#    cp .env.production.example .env.production
# 2. 填写实际的环境变量值
# 3. 确保 .env.production 添加到 .gitignore
# 4. 部署时会自动加载此文件

# ========================================
# 微信小程序配置（必需）
# ========================================
# 小程序 AppID
WECHAT_MINIPROGRAM_APP_ID=wx2382e1949d031ba6

# 小程序 AppSecret
WECHAT_MINIPROGRAM_APP_SECRET=f00d1a872e63be6e72b7ccc63eaa8a2d

# ========================================
# 应用基础配置（必需）
# ========================================
# 应用基础 URL
NEXT_PUBLIC_BASE_URL=https://hfb.yugioh.top
NEXT_PUBLIC_APP_URL=https://hfb.yugioh.top

# 内部 API 地址（用于定时任务等内部调用）
INTERNAL_API_URL=http://localhost:5000

# ========================================
# 数据库配置（必需）
# ========================================
# PostgreSQL 数据库连接字符串
PGDATABASE_URL=postgresql://user_7602973286103941146:6d1a5e86-6de8-4164-a92d-73b867d5e94a@cp-sharp-tower-5511e9e0.pg4.aidap-global.cn-beijing.volces.com:5432/Database_1770207199429?sslmode=require&channel_binding=require

# ========================================
# 微信支付配置（可选）
# ========================================
# 微信支付 AppID
# WECHAT_APPID=wx0831611146088354

# 微信支付商户号
# WECHAT_MCH_ID=1106605743

# 微信支付 API 密钥
# WECHAT_API_KEY=your_api_key_here

# 微信支付回调地址
# WECHAT_NOTIFY_URL=https://hfb.yugioh.top/api/payment/wechat/jsapi/callback

# ========================================
# 微信公众号配置（可选）
# ========================================
# 微信公众号 AppID
# WECHAT_MP_APPID=wx16c6fed9b7fc9c5c

# 微信公众号 AppSecret
# WECHAT_MP_SECRET=8a38f9a779dc832f39c6ab7d02ed3d58

# ========================================
# 对象存储配置（可选）
# ========================================
# AWS S3 兼容存储配置
# COZE_BUCKET_ENDPOINT_URL=https://your-bucket-endpoint
# COZE_BUCKET_NAME=your-bucket-name
# ALLOW_LOCAL_STORAGE_UPLOADS=false

# ========================================
# 阿里云短信配置（可选）
# ========================================
# 阿里云 AccessKey ID
# ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id

# 阿里云 AccessKey Secret
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret

# 阿里云短信签名
# ALIBABA_CLOUD_SMS_SIGN_NAME=your_sign_name

# ========================================
# 其他配置（可选）
# ========================================
# 证书密码
# WECHAT_CERT_P12_PASSWORD=your_cert_password_here

# Node.js 环境
NODE_ENV=production
