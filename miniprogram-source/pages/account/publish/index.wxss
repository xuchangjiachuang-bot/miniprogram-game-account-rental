/* pages/account/publish/index.wxss */
@import "../../../styles/variables.wxss";

.page {
  min-height: 100vh;
  background: var(--page-bg);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* 通用区块 */
.section {
  margin: 30rpx;
  padding: 30rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
}

.section-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--text-primary);
  margin-bottom: 30rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-title.required::before {
  content: '*';
  position: absolute;
  left: 0;
  color: var(--danger);
  font-weight: var(--font-weight-bold);
}

.section-tips {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  margin-top: 10rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-item-inline {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-label {
  font-size: var(--font-size-sm);
  color: var(--text-primary);
  margin-bottom: 15rpx;
  display: block;
}

.form-label.required::before {
  content: '*';
  color: var(--danger);
  margin-right: 5rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: var(--page-bg);
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  color: var(--text-primary);
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: var(--page-bg);
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  color: var(--text-primary);
  line-height: 1.6;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: var(--page-bg);
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  color: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  font-size: 32rpx;
  color: var(--text-secondary);
}

/* 时长列表 */
.duration-list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.duration-item {
  padding: 25rpx 10rpx;
  background: var(--page-bg);
  border-radius: var(--radius-md);
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.duration-item.active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.duration-label {
  font-size: var(--font-size-sm);
  color: var(--text-primary);
  margin-bottom: 5rpx;
  display: block;
}

.duration-price {
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-bold);
  color: var(--primary);
}

/* 提交栏 */
.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--card-bg);
  border-top: 1rpx solid var(--border-color);
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--primary);
  color: white;
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-lg);
  border: none;
}

.btn-submit[disabled] {
  background: var(--text-disabled);
  opacity: 0.5;
}
