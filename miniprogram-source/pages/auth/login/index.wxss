/* pages/auth/login/index.wxss */

.login-container {
  min-height: 100vh;
  padding: 80rpx 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

/* 表单区域 */
.form-section {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 40rpx;
}

.btn-wechat {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 28rpx;
  background: linear-gradient(to right, #07c160, #06ae56);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-icon {
  font-size: 40rpx;
}

/* 分隔线 */
.divider {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #eeeeee;
}

.divider-text {
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #999999;
}

/* 表单项 */
.form-item {
  margin-bottom: 30rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
}

.input-field.code-field {
  flex: 1;
  margin-right: 20rpx;
}

.btn-code {
  padding: 16rpx 32rpx;
  background: transparent;
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 8rpx;
  font-size: 24rpx;
  white-space: nowrap;
}

.btn-code.disabled {
  opacity: 0.5;
  color: #999999;
  border-color: #e0e0e0;
}

/* 登录按钮 */
.btn-login {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(to right, #667eea, #764ba2);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 40rpx;
}

.btn-login[disabled] {
  opacity: 0.5;
}

/* 协议 */
.agreement {
  margin-top: 30rpx;
  padding: 0 10rpx;
}

.agreement-label {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
}

agreement-label checkbox {
  transform: scale(0.8);
  margin-right: 8rpx;
}

.agreement-label .link {
  color: #667eea;
  margin: 0 4rpx;
}

/* 提示信息 */
.tips {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.tip-item {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  gap: 8rpx;
}
