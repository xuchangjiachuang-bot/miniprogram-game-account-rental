/* pages/chat/list/index.wxss */

/* 搜索栏 */
.search-bar {
  padding: 20rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 100rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
}

/* 聊天列表 */
.chat-list {
  min-height: calc(100vh - 120rpx);
}

.chat-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #f5f5f5;
}

.chat-avatar {
  position: relative;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
}

.unread-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  background: #ff4757;
  color: #ffffff;
  border-radius: 18rpx;
  font-size: 20rpx;
  line-height: 36rpx;
  text-align: center;
  border: 4rpx solid #ffffff;
}

.chat-content {
  flex: 1;
  min-width: 0;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.chat-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-time {
  font-size: 22rpx;
  color: #999999;
  flex-shrink: 0;
  margin-left: 20rpx;
}

.chat-message {
  font-size: 26rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-type {
  color: #667eea;
  margin-left: 8rpx;
}

.chat-status {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.status-tag {
  padding: 8rpx 16rpx;
  background: #f0f0f0;
  color: #666666;
  border-radius: 8rpx;
  font-size: 22rpx;
}

/* 加载中 */
.loading {
  padding: 40rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #999999;
}

/* 空状态 */
.empty {
  padding: 80rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

/* 底部占位 */
.tabbar-placeholder {
  height: 100rpx;
}
