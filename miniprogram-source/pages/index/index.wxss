/* pages/index/index.wxss */

/* 轮播图区域 */
.carousel-section {
  width: 100%;
  height: 400rpx;
  position: relative;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.carousel {
  width: 100%;
  height: 100%;
}

.carousel-image {
  width: 100%;
  height: 100%;
}

.carousel-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
  color: #ffffff;
}

.carousel-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.carousel-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 备用标题区域 */
.fallback-title-section {
  padding: 60rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  text-align: center;
}

.badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 100rpx;
  font-size: 24rpx;
  color: #ffffff;
  margin-bottom: 30rpx;
}

.main-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.gradient-text {
  background: linear-gradient(to right, #f6d365, #fda085);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sub-title {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 40rpx;
}

.publish-btn {
  background: #ffffff;
  color: #667eea;
  border: none;
  padding: 24rpx 80rpx;
  border-radius: 100rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* 筛选区域 */
.filter-section {
  background: #ffffff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.filter-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.filter-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.filter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  margin: -12rpx;
}

.filter-item {
  flex: 1;
  min-width: 45%;
  padding: 12rpx;
}

.filter-label {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1a1a1a;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
}

.range-input {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.range-input-field {
  flex: 1;
  padding: 20rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  text-align: center;
}

.range-separator {
  color: #999999;
}

.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

/* 展开的筛选器 */
.more-filters {
  margin-top: 30rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #eeeeee;
}

.filter-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.skin-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.skin-item {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 100rpx;
  font-size: 26rpx;
  color: #666666;
  position: relative;
}

.skin-item.active {
  background: #667eea;
  color: #ffffff;
}

.skin-check {
  font-size: 20rpx;
  margin-right: 8rpx;
}

/* 账号列表 */
.account-list {
  padding: 0 20rpx;
  padding-bottom: 40rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 30rpx;
}

.account-count {
  font-size: 26rpx;
  color: #999999;
}

.account-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.account-card {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.card-image {
  width: 240rpx;
  flex-shrink: 0;
}

.card-img {
  width: 100%;
  height: 280rpx;
}

.card-content {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-info-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.info-card {
  flex: 1;
  padding: 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.ratio-card .info-value {
  color: #ff6b6b;
}

.card-attributes {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: auto;
}

.attribute-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.attr-label {
  font-size: 22rpx;
  color: #999999;
}

.attr-value {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
}

.card-price {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.price-label {
  font-size: 24rpx;
  color: #999999;
  margin-right: 12rpx;
}

.price-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #667eea;
}

/* 加载更多 */
.load-more {
  padding: 40rpx 0;
  text-align: center;
}

/* 加载中 */
.loading {
  padding: 40rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #999999;
}

/* 空状态 */
.empty {
  padding: 80rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

/* 底部占位 */
.tabbar-placeholder {
  height: 100rpx;
}

/* 按钮样式 */
.btn-outline {
  flex: 1;
  padding: 20rpx;
  background: transparent;
  border: 2rpx solid #667eea;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #667eea;
}

.btn-ghost {
  padding: 20rpx 40rpx;
  background: transparent;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #999999;
}
