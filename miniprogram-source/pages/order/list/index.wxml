<!-- pages/order/list/index.wxml -->
<view class="page">
  <!-- 标签切换 -->
  <view class="tabs">
    <view 
      class="tab-item {{currentTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      bindtap="onTabChange"
      data-tab="{{item.key}}"
    >
      {{item.name}}
      <view class="tab-badge" wx:if="{{item.count > 0}}">{{item.count}}</view>
    </view>
  </view>

  <!-- 订单列表 -->
  <view class="order-list">
    <view 
      class="order-card"
      wx:for="{{orders}}"
      wx:key="id"
      bindtap="onOrderTap"
      data-order="{{item}}"
    >
      <view class="order-header">
        <view class="order-number">订单号: {{item.order_number}}</view>
        <view class="order-status {{item.status}}">{{item.statusText}}</view>
      </view>

      <view class="order-body">
        <view class="account-info">
          <image class="account-image" src="{{item.account.image}}" mode="aspectFill" />
          <view class="account-details">
            <view class="account-name">{{item.account.name}}</view>
            <view class="account-metas">
              <text class="meta">哈夫币: {{item.account.coins}}</text>
              <text class="meta">比例: {{item.account.ratio}}</text>
            </view>
          </view>
        </view>

        <view class="order-prices">
          <view class="price-row">
            <text class="price-label">租金</text>
            <text class="price-value">¥{{item.rental_price}}</text>
          </view>
          <view class="price-row">
            <text class="price-label">押金</text>
            <text class="price-value">¥{{item.deposit}}</text>
          </view>
          <view class="price-row total">
            <text class="price-label">总价</text>
            <text class="price-value">¥{{item.total_price}}</text>
          </view>
        </view>
      </view>

      <view class="order-time">
        <text class="time-label">租赁时间</text>
        <text class="time-value">{{item.rental_start}} ~ {{item.rental_end}}</text>
      </view>

      <view class="order-actions" wx:if="{{item.showActions}}">
        <button 
          class="btn-action btn-outline"
          wx:for="{{item.actions}}"
          wx:key="key"
          bindtap="onActionTap"
          data-action="{{item}}"
          data-id="{{item.id}}"
          catchtap="true"
        >
          {{item.text}}
        </button>
      </view>
    </view>

    <!-- 加载中 -->
    <view class="loading" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{!loading && orders.length === 0}}">
      <view class="empty-icon">📦</view>
      <view class="empty-text">暂无订单</view>
      <view class="empty-hint" wx:if="{{currentTab === 'all'}}">去首页租赁一个账号吧</view>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="tabbar-placeholder"></view>
</view>
