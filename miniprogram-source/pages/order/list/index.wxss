/* pages/order/list/index.wxss */

.tabs {
  display: flex;
  background: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #667eea;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #667eea;
  border-radius: 2rpx;
}

.tab-badge {
  display: inline-block;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 10rpx;
  background: #ff4757;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 20rpx;
  line-height: 32rpx;
  margin-left: 8rpx;
  vertical-align: middle;
}

/* 订单列表 */
.order-list {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

.order-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-number {
  font-size: 24rpx;
  color: #999999;
}

.order-status {
  font-size: 26rpx;
  font-weight: 600;
}

.order-status.pending_payment {
  color: #ff6b6b;
}

.order-status.pending_start {
  color: #ffa502;
}

.order-status.renting {
  color: #667eea;
}

.order-status.completed {
  color: #2ed573;
}

.order-status.cancelled {
  color: #999999;
}

.order-body {
  display: flex;
  padding: 20rpx 0;
  gap: 20rpx;
}

.account-info {
  flex: 1;
  display: flex;
  gap: 16rpx;
}

.account-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.account-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.account-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.account-metas {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.meta {
  font-size: 24rpx;
  color: #999999;
}

.order-prices {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  text-align: right;
}

.price-row {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 12rpx;
}

.price-label {
  font-size: 22rpx;
  color: #999999;
}

.price-value {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.price-row.total .price-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #667eea;
}

.order-time {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-top: 1rpx solid #f5f5f5;
}

.time-label {
  font-size: 22rpx;
  color: #999999;
}

.time-value {
  font-size: 24rpx;
  color: #666666;
}

.order-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.btn-action {
  flex: 1;
  padding: 16rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
}

.btn-outline {
  background: transparent;
  color: #667eea;
  border: 2rpx solid #667eea;
}

/* 加载中 */
.loading {
  padding: 40rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #999999;
}

/* 空状态 */
.empty {
  padding: 80rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

/* 底部占位 */
.tabbar-placeholder {
  height: 100rpx;
}
