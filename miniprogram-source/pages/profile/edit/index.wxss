/* pages/profile/edit/index.wxss */

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  background: #ffffff;
  margin-bottom: 20rpx;
}

.avatar-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f5f5f5;
  margin-bottom: 16rpx;
  border: 4rpx solid #e0e0e0;
}

.avatar-tip {
  font-size: 24rpx;
  color: #667eea;
}

/* 表单区域 */
.form-section {
  background: #ffffff;
  padding: 0 30rpx;
}

.form-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  font-size: 28rpx;
  color: #1a1a1a;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #1a1a1a;
}

.picker-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.form-value {
  font-size: 28rpx;
  color: #1a1a1a;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bind-link {
  color: #667eea;
  font-size: 26rpx;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  line-height: 1.6;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: #999999;
  margin-top: 8rpx;
}

/* 操作区域 */
.action-section {
  padding: 40rpx 30rpx;
}

.btn-save {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(to right, #667eea, #764ba2);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-save[disabled] {
  opacity: 0.5;
}
