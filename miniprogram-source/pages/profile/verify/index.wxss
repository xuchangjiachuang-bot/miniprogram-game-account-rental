/* pages/profile/verify/index.wxss */
@import "../../../styles/variables.wxss";

.page {
  min-height: 100vh;
  background: var(--page-bg);
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* 认证状态 */
.verify-status {
  padding: 60rpx 40rpx;
  text-align: center;
}

.verify-status.status-none {
  background: linear-gradient(135deg, #8c8c8c 0%, #595959 100%);
}

.verify-status.status-pending {
  background: linear-gradient(135deg, #40a9ff 0%, #1890ff 100%);
}

.verify-status.status-approved {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
}

.verify-status.status-rejected {
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
}

.status-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.status-text {
  font-size: 36rpx;
  font-weight: var(--font-weight-bold);
  color: white;
  margin-bottom: 10rpx;
}

.status-desc {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.8);
}

/* 通用区块 */
.section {
  margin: 30rpx;
  padding: 30rpx;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
}

.section-title {
  font-size: var(--font-size-md);
  font-weight: var(--font-weight-medium);
  color: var(--text-primary);
  margin-bottom: 30rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-title.required::before {
  content: '*';
  position: absolute;
  left: 0;
  color: var(--danger);
  font-weight: var(--font-weight-bold);
}

/* 表单输入 */
.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  background: var(--page-bg);
  border-radius: var(--radius-md);
  font-size: var(--font-size-md);
  color: var(--text-primary);
}

/* 身份证上传 */
.id-card-upload {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.upload-item {
  position: relative;
  aspect-ratio: 1.58;
  background: var(--page-bg);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.id-card-image {
  width: 100%;
  height: 100%;
}

.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.placeholder-icon {
  font-size: 60rpx;
}

.placeholder-text {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

/* 认证信息 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.info-value {
  font-size: var(--font-size-md);
  color: var(--text-primary);
}

/* 提示 */
.tips {
  margin: 0 30rpx;
  padding: 20rpx;
  background: var(--warning-bg);
  border-radius: var(--radius-md);
}

.tips .tip-item {
  font-size: var(--font-size-xs);
  color: var(--warning-text);
  line-height: 1.8;
  margin-bottom: 5rpx;
}

.tips .tip-item:last-child {
  margin-bottom: 0;
}

/* 提交栏 */
.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--card-bg);
  border-top: 1rpx solid var(--border-color);
}

.btn-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--primary);
  color: white;
  font-size: var(--font-size-lg);
  font-weight: var(--font-weight-medium);
  border-radius: var(--radius-lg);
  border: none;
}

.btn-submit[disabled] {
  background: var(--text-disabled);
  opacity: 0.5;
}
