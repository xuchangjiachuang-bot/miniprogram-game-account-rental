/* pages/wallet/recharge/index.wxss */

/* 余额展示 */
.balance-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 30rpx;
  text-align: center;
  color: #ffffff;
}

.balance-label {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.balance-amount {
  font-size: 64rpx;
  font-weight: 700;
}

/* 区块 */
.section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

/* 金额网格 */
.amount-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.amount-item {
  padding: 30rpx 0;
  background: #f5f5f5;
  border-radius: 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.amount-item.active {
  background: #f0f3ff;
  border-color: #667eea;
}

.amount-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.amount-desc {
  display: block;
  font-size: 22rpx;
  color: #ff6b6b;
}

/* 自定义金额 */
.custom-amount {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.custom-label {
  font-size: 26rpx;
  color: #666666;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.custom-input {
  flex: 1;
  font-size: 32rpx;
  color: #1a1a1a;
}

.custom-unit {
  font-size: 26rpx;
  color: #999999;
  margin-left: 12rpx;
}

/* 支付方式 */
.payment-methods {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.payment-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.payment-item.active {
  background: #f0f3ff;
  border-color: #667eea;
}

.payment-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.payment-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.payment-name {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.payment-desc {
  font-size: 22rpx;
  color: #999999;
}

.payment-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #667eea;
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 提示 */
.tips {
  padding: 30rpx;
  background: #fff9e6;
  border: 1rpx solid #ffeaa7;
  border-radius: 12rpx;
  margin: 0 20rpx;
}

.tip-item {
  font-size: 24rpx;
  color: #856404;
  line-height: 1.8;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #eeeeee;
  z-index: 100;
}

.total-info {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.total-label {
  font-size: 26rpx;
  color: #666666;
}

.total-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: #667eea;
}

.total-gift {
  font-size: 24rpx;
  color: #ff6b6b;
}

.btn-pay {
  padding: 24rpx 48rpx;
  background: linear-gradient(to right, #667eea, #764ba2);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-pay[disabled] {
  opacity: 0.5;
}
