/* app.wxss */
@import "styles/variables.wxss";

page {
  background-color: var(--bg-background);
  color: var(--text-foreground);
  font-size: 28rpx;
  line-height: 1.5;
}

/* 通用样式 */
.container {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(to right, #2563eb, #9333ea);
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-secondary {
  background: white;
  color: #6366f1;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-danger {
  background: #ef4444;
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 卡片样式 */
.card {
  background: white;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 输入框样式 */
.input {
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

/* 文本样式 */
.text-primary {
  color: #6366f1;
}

.text-secondary {
  color: #6b7280;
}

.text-success {
  color: #10b981;
}

.text-warning {
  color: #f59e0b;
}

.text-danger {
  color: #ef4444;
}

.text-small {
  font-size: 24rpx;
}

.text-large {
  font-size: 32rpx;
}

.text-bold {
  font-weight: 600;
}

/* 布局工具类 */
.flex {
  display: flex;
}

.flex-row {
  flex-direction: row;
}

.flex-col {
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.gap-2 {
  gap: 16rpx;
}

.gap-4 {
  gap: 32rpx;
}

.p-2 {
  padding: 16rpx;
}

.p-4 {
  padding: 32rpx;
}

.mt-2 {
  margin-top: 16rpx;
}

.mt-4 {
  margin-top: 32rpx;
}

.mb-2 {
  margin-bottom: 16rpx;
}

.mb-4 {
  margin-bottom: 32rpx;
}

/* 徽章样式 */
.badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.badge-primary {
  background: #6366f1;
  color: white;
}

.badge-secondary {
  background: #f3f4f6;
  color: #6b7280;
}

.badge-success {
  background: #10b981;
  color: white;
}

.badge-warning {
  background: #f59e0b;
  color: white;
}

.badge-danger {
  background: #ef4444;
  color: white;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #e5e7eb;
  margin: 24rpx 0;
}

/* 加载样式 */
.loading {
  text-align: center;
  padding: 80rpx 0;
  color: #6b7280;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 120rpx 0;
  color: #6b7280;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #9ca3af;
}
