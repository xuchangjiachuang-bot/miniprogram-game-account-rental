/* components/login-modal/index.wxss */

.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4rpx);
}

.modal-content {
  position: relative;
  width: 560rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.2);
  animation: modalSlideIn 0.3s ease-out;
}

@keyframes modalSlideIn {
  from {
    transform: scale(0.9);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

.modal-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.modal-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn-wechat-login {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  width: 100%;
  padding: 28rpx 0;
  background: linear-gradient(135deg, #07c160 0%, #059b4c 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.3);
  transition: all 0.3s;
}

.btn-wechat-login.btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-wechat-login::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  line-height: 1;
}

.btn-text {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
}
