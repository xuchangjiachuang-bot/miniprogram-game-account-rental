/* pages/account/detail/index.wxss */
page {
  background: #f5f5f5;
  min-height: 100vh;
}

.page {
  padding-bottom: 120rpx;
}

/* 轮播图容器 */
.swiper-container {
  position: relative;
  width: 100%;
  height: 600rpx;
  background: #1a1a1a;
}

.account-swiper {
  width: 100%;
  height: 100%;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* 图片指示器 */
.swiper-indicators {
  position: absolute;
  bottom: 30rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12rpx;
}

.indicator {
  position: relative;
}

.indicator-dot {
  width: 12rpx;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 50%;
  transition: all 0.3s ease;
}

.indicator-dot.active {
  width: 30rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.9);
}

/* 左右切换按钮 */
.swiper-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  color: #ffffff;
  font-size: 48rpx;
  cursor: pointer;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  transition: all 0.3s ease;
}

.swiper-btn.prev {
  left: 20rpx;
}

.swiper-btn.next {
  right: 20rpx;
}

.swiper-btn:active {
  opacity: 0.7;
  transform: translateY(-50%) scale(0.95);
}

/* 信息区域 */
.info-section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  margin-top: -30rpx;
  border-radius: 30rpx 30rpx 0 0;
  position: relative;
  z-index: 10;
}

.account-header {
  margin-bottom: 20rpx;
}

.account-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.account-status {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #f0f9f4;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.account-status.available {
  color: #2ed573;
  background: #f0f9f4;
}

.account-status.available .status-dot {
  background: #2ed573;
}

.account-status.rented {
  color: #ffa502;
  background: #fff8e1;
}

.account-status.rented .status-dot {
  background: #ffa502;
}

.account-status.offline {
  color: #ff4757;
  background: #ffeef0;
}

.account-status.offline .status-dot {
  background: #ff4757;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

/* 平台标签 */
.platform-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 6rpx;
  margin-bottom: 24rpx;
  font-weight: 500;
}

/* 信息卡片网格 */
.info-card-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.info-card {
  padding: 20rpx 12rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 16rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-height: 140rpx;
}

.info-card.coins {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

.info-card.ratio {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.info-card.safebox {
  background: linear-gradient(135deg, #d299c2 0%, #fef9d7 100%);
}

.info-card.level {
  background: linear-gradient(135deg, #89f7fe 0%, #66a6ff 100%);
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: rgba(0, 0, 0, 0.6);
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(0, 0, 0, 0.9);
  word-break: break-word;
}

/* 属性区域 */
.attributes-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #667eea;
}

.attribute-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.attribute-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f7f8fc;
  border-radius: 12rpx;
  transition: all 0.3s ease;
}

.attribute-item:active {
  background: #eef0f8;
  transform: scale(0.98);
}

.attr-label {
  font-size: 26rpx;
  color: #666666;
  font-weight: 500;
}

.attr-value {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
}

/* 皮肤区域 */
.skins-section {
  margin-bottom: 30rpx;
}

.skins-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skin-tag {
  display: inline-block;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
  color: #667eea;
  font-size: 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(102, 126, 234, 0.3);
  font-weight: 500;
}

/* 描述区域 */
.desc-section {
  margin-bottom: 30rpx;
}

.desc-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #666666;
  padding: 24rpx;
  background: #f7f8fc;
  border-radius: 12rpx;
  white-space: pre-wrap;
}

/* 价格区域 */
.price-section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 16rpx 0;
}

.price-label {
  font-size: 28rpx;
  color: #666666;
  font-weight: 500;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.price-row.total {
  padding-top: 24rpx;
  margin-top: 24rpx;
  border-top: 2rpx dashed #eeeeee;
}

.price-row.total .price-value {
  font-size: 52rpx;
  font-weight: 800;
  color: #667eea;
  text-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
}

.btn-service,
.btn-favorite {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx;
  background: transparent;
  border: none;
  font-size: 22rpx;
  color: #666666;
  margin-right: 20rpx;
  transition: all 0.3s ease;
}

.btn-service text:first-child,
.btn-favorite text:first-child {
  font-size: 40rpx;
}

.btn-service:active,
.btn-favorite:active {
  transform: scale(0.95);
}

.btn-favorite.active text {
  color: #ffa502;
}

.btn-rent {
  flex: 3;
  padding: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  transition: all 0.3s ease;
}

.btn-rent[disabled] {
  background: #cccccc;
  box-shadow: none;
}

.btn-rent:not([disabled]):active {
  transform: translateY(-2rpx);
  box-shadow: 0 12rpx 32rpx rgba(102, 126, 234, 0.5);
}

/* 底部占位 */
.bottom-placeholder {
  height: 180rpx;
}
