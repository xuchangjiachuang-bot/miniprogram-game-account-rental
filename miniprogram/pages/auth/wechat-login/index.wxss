/* pages/auth/wechat-login/index.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef2ff 0%, #f5f3ff 50%, #ffffff 100%);
}

.login-container {
  min-height: 100vh;
  padding: 80rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* Logo Section */
.logo-section {
  text-align: center;
  margin-bottom: 120rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(147, 51, 234, 0.2);
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.app-slogan {
  font-size: 26rpx;
  color: #6b7280;
}

/* Login Form */
.login-form {
  width: 100%;
  max-width: 600rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  text-align: center;
  margin-bottom: 24rpx;
}

.form-desc {
  font-size: 26rpx;
  color: #6b7280;
  text-align: center;
  margin-bottom: 60rpx;
  line-height: 1.6;
}

/* Auth Button */
.auth-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(90deg, #2563eb 0%, #9333ea 100%);
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(147, 51, 234, 0.3);
  margin-bottom: 40rpx;
}

.auth-btn.disabled {
  opacity: 0.6;
}

.auth-btn:active {
  transform: scale(0.98);
}

/* Agreement */
.agreement {
  font-size: 24rpx;
  color: #6b7280;
  text-align: center;
  line-height: 1.6;
}

.agreement .link {
  color: #9333ea;
}

/* Back Section */
.back-section {
  margin-top: 80rpx;
}

.back-btn {
  padding: 24rpx 48rpx;
  border: 2rpx solid #e5e7eb;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #6b7280;
  transition: all 0.3s;
}

.back-btn:active {
  background: #f9fafb;
  border-color: #d1d5db;
}
