/* pages/index/index.wxss */

/* 页面容器 - 禁止横向滚动 */
.page {
  width: 100%;
  overflow-x: hidden;
  background: #ffffff;
}

/* ============ Hero Section (轮播图区域) ============ */
.hero-section {
  width: 100%;
  max-width: 100%;
  background: #ffffff;
  position: relative;
  box-sizing: border-box;
}

.hero-container {
  width: 100%;
  max-width: 100%;
  padding: 30rpx;
  box-sizing: border-box;
}

.carousel {
  width: 100%;
  height: 360rpx;
  position: relative;
  border-radius: 20rpx;
  overflow: hidden;
  background: #111827;
}

.carousel-item {
  width: 100%;
  height: 100%;
  position: relative;
}

.carousel-image {
  width: 100%;
  height: 100%;
  display: block;
}

.carousel-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
}

.carousel-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 40rpx;
  color: #ffffff;
  z-index: 1;
  box-sizing: border-box;
}

.carousel-title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.carousel-desc {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

/* 发布按钮区域（固定在轮播图下方） */
.publish-section {
  display: flex;
  justify-content: center;
  padding: 0 30rpx 30rpx;
  box-sizing: border-box;
}

.publish-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 60rpx;
  background: linear-gradient(90deg, #2563eb 0%, #9333ea 100%);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(147, 51, 234, 0.4);
  transition: all 0.3s;
}

.publish-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(147, 51, 234, 0.3);
}

.publish-icon {
  font-size: 32rpx;
  font-weight: 300;
}

.publish-text {
  font-size: 28rpx;
  font-weight: 600;
}

/* 备用 Hero */
.fallback-hero {
  padding: 60rpx 40rpx;
  text-align: center;
  box-sizing: border-box;
}

.badge {
  display: inline-block;
  padding: 10rpx 24rpx;
  background: linear-gradient(90deg, #2563eb 0%, #9333ea 100%);
  border-radius: 50rpx;
  font-size: 24rpx;
  color: #ffffff;
  margin-bottom: 30rpx;
}

.main-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.gradient-text {
  background: linear-gradient(90deg, #2563eb, #9333ea);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.sub-title {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.hero-btn {
  display: inline-block;
  padding: 20rpx 60rpx;
  background: linear-gradient(90deg, #2563eb 0%, #9333ea 100%);
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(147, 51, 234, 0.4);
}

/* ============ Filter Section (筛选区域) ============ */
.filter-section {
  width: 100%;
  max-width: 100%;
  background: #ffffff;
  padding: 30rpx 30rpx 40rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.filter-container {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.filter-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.filter-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  color: #9333ea;
}

.filter-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

/* 筛选行 */
.filter-row {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
  margin: 0 0 20rpx;
  gap: 20rpx;
  box-sizing: border-box;
  justify-content: flex-start;
}

.filter-row-7 {
  margin-bottom: 20rpx;
}

.filter-row-3 {
  margin-bottom: 20rpx;
}

/* 筛选项 */
.filter-item {
  flex: 0 0 calc(50% - 10rpx);
  min-width: 0;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.filter-item-7 {
  flex: 0 0 calc(50% - 10rpx);
}

.filter-item-3 {
  flex: 0 0 calc(50% - 10rpx);
}

.filter-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
  font-weight: 500;
}

/* Picker Box */
.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #1f2937;
  transition: all 0.3s;
  width: 100%;
  box-sizing: border-box;
}

.picker-box:active {
  border-color: #9333ea;
  background: #faf5ff;
}

.picker-arrow {
  font-size: 18rpx;
  color: #9ca3af;
  flex-shrink: 0;
}

/* Range Input */
.range-box {
  display: flex;
  align-items: center;
  gap: 10rpx;
  width: 100%;
  box-sizing: border-box;
}

.range-input {
  flex: 1;
  min-width: 0;
  padding: 14rpx 14rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #1f2937;
  text-align: center;
  box-sizing: border-box;
  line-height: 1.4;
  height: 60rpx;
}

.range-input:focus {
  border-color: #9333ea;
  background: #faf5ff;
}

.range-separator {
  font-size: 22rpx;
  color: #9ca3af;
  font-weight: 500;
  flex-shrink: 0;
}

/* 搜索行 */
.search-row {
  width: 100%;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.search-box {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.search-icon {
  position: absolute;
  left: 24rpx;
  font-size: 28rpx;
  color: #9ca3af;
  z-index: 1;
}

.search-input {
  width: 100%;
  padding: 20rpx 24rpx 20rpx 60rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.search-input:focus {
  border-color: #9333ea;
  background: #faf5ff;
}

/* 操作行 */
.action-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.btn-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 24rpx;
  background: #9333ea;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  flex: 1;
  justify-content: center;
  min-width: 0;
  box-sizing: border-box;
}

.btn-toggle:active {
  background: #7c3aed;
}

.btn-reset {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 32rpx;
  background: #ffffff;
  color: #ef4444;
  border: 2rpx solid #fee2e2;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  flex-shrink: 0;
  box-sizing: border-box;
}

.btn-reset:active {
  background: #fef2f2;
}

/* Skin Filter */
.skin-filter {
  padding-top: 20rpx;
  border-top: 2rpx solid #f3f4f6;
  width: 100%;
  box-sizing: border-box;
}

.skin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.skin-label {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 600;
}

.skin-count {
  font-size: 22rpx;
  color: #9333ea;
  background: #faf5ff;
  padding: 6rpx 16rpx;
  border-radius: 50rpx;
}

.skin-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skin-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 50rpx;
  font-size: 24rpx;
  color: #4b5563;
  transition: all 0.3s;
  white-space: nowrap;
}

.skin-tag.active {
  background: #9333ea;
  border-color: #9333ea;
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(147, 51, 234, 0.4);
}

.skin-tag:active {
  transform: scale(0.95);
}

.skin-check {
  font-size: 20rpx;
  font-weight: 700;
}

/* ============ Account Section (账号列表) ============ */
.account-section {
  width: 100%;
  max-width: 100%;
  padding: 0 30rpx 30rpx;
  min-height: 400rpx;
  box-sizing: border-box;
}

.account-container {
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}

.account-count {
  font-size: 24rpx;
  color: #6b7280;
}

/* Account Grid */
.account-grid {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
  margin: -10rpx;
  box-sizing: border-box;
}

.account-card {
  width: calc(50% - 20rpx);
  margin: 10rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
  box-sizing: border-box;
}

.account-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.12);
}

/* Card Image */
.card-image {
  position: relative;
  width: 100%;
  height: 260rpx;
  background: #f9fafb;
}

.card-img {
  width: 100%;
  height: 100%;
  display: block;
}

.card-status {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 6rpx 16rpx;
  border-radius: 50rpx;
  font-size: 20rpx;
  font-weight: 600;
  backdrop-filter: blur(10rpx);
}

.card-status.available {
  background: rgba(16, 185, 129, 0.9);
  color: #ffffff;
}

.card-status.renting {
  background: rgba(245, 158, 11, 0.9);
  color: #ffffff;
}

.card-status.off_shelf {
  background: rgba(107, 114, 128, 0.9);
  color: #ffffff;
}

/* 平台标签 */
.platform-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 12rpx;
  background: rgba(147, 51, 234, 0.9);
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
  backdrop-filter: blur(10rpx);
}

/* Card Content */
.card-content {
  padding: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.info-box {
  flex: 1;
  min-width: 0;
  padding: 12rpx 16rpx;
  background: #f9fafb;
  border-radius: 10rpx;
  text-align: center;
  box-sizing: border-box;
}

.info-box.coins {
  background: linear-gradient(135deg, #faf5ff 0%, #f3e8ff 100%);
}

.info-box.ratio {
  background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
}

.info-label {
  display: block;
  font-size: 20rpx;
  color: #6b7280;
  margin-bottom: 4rpx;
}

.info-value {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2937;
}

.attributes-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 12rpx;
  background: #f9fafb;
  border-radius: 10rpx;
}

.attribute {
  text-align: center;
  flex: 1;
  min-width: 0;
}

.attr-label {
  display: block;
  font-size: 20rpx;
  color: #6b7280;
  margin-bottom: 4rpx;
}

.attr-value {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  color: #1f2937;
}

/* KD和地区行 */
.kd-region-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 8rpx 12rpx;
  background: #fafafa;
  border-radius: 8rpx;
}

.kd-text {
  font-size: 22rpx;
  color: #6b7280;
  font-weight: 600;
}

.region-text {
  font-size: 22rpx;
  color: #6b7280;
}

/* 皮肤标签行 */
.skins-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.skin-tag {
  padding: 4rpx 12rpx;
  background: linear-gradient(135deg, #9333ea 0%, #7c3aed 100%);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.skin-more {
  padding: 4rpx 12rpx;
  background: #e5e7eb;
  color: #6b7280;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
}

/* 价格行 */
.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 12rpx;
  background: #fdf4ff;
  border-radius: 10rpx;
}

.price-box {
  text-align: center;
  flex: 1;
  min-width: 0;
}

.price-label {
  display: block;
  font-size: 20rpx;
  color: #7c3aed;
  margin-bottom: 4rpx;
}

.price-value {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2937;
}

.price-value.total {
  color: #10b981;
  font-size: 28rpx;
}

/* 租期 */
.rental-duration {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 10rpx;
  background: #fef3c7;
  border-radius: 8rpx;
}

.duration-label {
  font-size: 22rpx;
  color: #f59e0b;
  margin-right: 8rpx;
  font-weight: 600;
}

.duration-value {
  font-size: 22rpx;
  color: #1f2937;
  font-weight: 700;
}

.card-price {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 2rpx solid #f3f4f6;
}

.price-label {
  font-size: 24rpx;
  color: #6b7280;
}

.price-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #9333ea;
}

/* Load More */
.load-more {
  margin-top: 40rpx;
  text-align: center;
}

.btn-load-more {
  display: inline-block;
  padding: 20rpx 60rpx;
  background: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #9333ea;
  font-weight: 600;
  transition: all 0.3s;
}

.btn-load-more:active {
  background: #faf5ff;
  border-color: #9333ea;
}

/* Loading */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #9333ea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading text {
  font-size: 24rpx;
  color: #6b7280;
}

/* Empty */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #6b7280;
}

/* Tabbar Placeholder */
.tabbar-placeholder {
  height: 120rpx;
  width: 100%;
}
