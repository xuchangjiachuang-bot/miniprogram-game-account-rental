/* pages/order/payment/wechat/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

.container {
  padding: 20rpx;
}

/* Header */
.header {
  padding: 40rpx 0;
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #999;
}

/* Card */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* Account Info */
.account-info .info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.account-info .info-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: #666;
}

.value {
  font-size: 26rpx;
  color: #333;
}

/* Price Info */
.price-info .info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.divider {
  height: 1rpx;
  background: #e5e5e5;
  margin: 20rpx 0;
}

.price-info .total {
  margin-top: 10rpx;
  margin-bottom: 0;
}

.price-info .total .label {
  font-size: 28rpx;
  font-weight: 600;
}

.price-info .total .value {
  font-size: 32rpx;
  font-weight: 700;
}

.price-info .total .value.highlight {
  color: #07c160;
}

/* Payment Method */
.method-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e5e5e5;
  transition: all 0.3s;
}

.method-item.selected {
  border-color: #07c160;
  background: #f0fff9;
}

.method-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 16rpx;
}

.method-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.method-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

/* Footer */
.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.total-price {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 26rpx;
  color: #666;
}

.price-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #07c160;
}

.pay-btn {
  width: 240rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.pay-btn.disabled {
  opacity: 0.6;
}
