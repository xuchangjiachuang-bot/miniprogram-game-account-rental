/* pages/wallet/bill/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #ffffff;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-arrow {
  font-size: 36rpx;
  color: #333;
  font-weight: 700;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.nav-placeholder {
  width: 60rpx;
}

/* 月份选择器 */
.month-selector {
  padding: 20rpx 30rpx;
  background: #ffffff;
  margin-bottom: 20rpx;
}

.selector-box {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
}

.selector-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.selector-arrow {
  font-size: 20rpx;
  color: #999;
}

/* 账单汇总 */
.bill-summary {
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.summary-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  color: #ffffff;
}

.summary-title {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 30rpx;
  text-align: center;
}

.summary-row {
  display: flex;
  gap: 40rpx;
  margin-bottom: 30rpx;
}

.summary-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.summary-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 700;
}

.summary-divider {
  width: 1rpx;
  background: rgba(255, 255, 255, 0.3);
}

.summary-net {
  text-align: center;
  padding: 24rpx 0;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.net-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-right: 12rpx;
}

.net-value {
  font-size: 36rpx;
  font-weight: 700;
}

.net-value.income {
  color: #07c160;
}

.net-value.expense {
  color: #ff4444;
}

.summary-info {
  text-align: center;
}

.info-text {
  font-size: 22rpx;
  opacity: 0.8;
}

/* 分类统计 */
.category-section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.category-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.category-name {
  font-size: 28rpx;
  color: #333;
}

.category-count {
  font-size: 22rpx;
  color: #999;
}

.category-amount {
  text-align: right;
}

.amount-value {
  font-size: 32rpx;
  font-weight: 600;
}

.amount-value.income {
  color: #07c160;
}

.amount-value.expense {
  color: #ff4444;
}

/* 每日统计 */
.daily-section {
  background: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.daily-chart {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.chart-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.row-date {
  width: 80rpx;
  font-size: 22rpx;
  color: #666;
  text-align: right;
}

.row-bar-wrapper {
  flex: 1;
  display: flex;
  gap: 4rpx;
  height: 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  overflow: hidden;
}

.row-bar {
  height: 100%;
  min-width: 2rpx;
  border-radius: 12rpx;
  transition: width 0.3s;
}

.row-bar.income {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
}

.row-bar.expense {
  background: linear-gradient(135deg, #ff4444 0%, #ff6666 100%);
}

.row-amounts {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 120rpx;
}

.row-amounts .amount {
  font-size: 20rpx;
  text-align: right;
}

.row-amounts .amount.income {
  color: #07c160;
}

.row-amounts .amount.expense {
  color: #ff4444;
}

/* 交易明细 */
.transactions-section {
  background: #ffffff;
  padding: 30rpx;
}

.transaction-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.transaction-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.transaction-type {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.transaction-desc {
  font-size: 24rpx;
  color: #666;
}

.transaction-time {
  font-size: 22rpx;
  color: #999;
}

.transaction-amount {
  font-size: 32rpx;
  font-weight: 600;
}

.transaction-amount.income {
  color: #07c160;
}

.transaction-amount.expense {
  color: #ff4444;
}

/* 空状态 */
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}
