/* pages/wallet/index.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 余额卡片 */
.balance-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  color: #ffffff;
}

.balance-header {
  margin-bottom: 40rpx;
}

.balance-title {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.balance-amount {
  font-size: 64rpx;
  font-weight: 700;
}

.balance-actions {
  display: flex;
  gap: 40rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.recharge-icon::after {
  content: '+';
}

.withdraw-icon::after {
  content: '-';
}

.action-text {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 统计卡片 */
.statistics-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.period-selector {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
}

.period-text {
  font-size: 24rpx;
  color: #666;
}

.period-arrow {
  font-size: 16rpx;
  color: #999;
}

/* 统计汇总 */
.statistics-summary {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #999;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 700;
}

.summary-value.income {
  color: #07c160;
}

.summary-value.expense {
  color: #ff4444;
}

/* 图表 */
.chart-container {
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.chart-scroll {
  width: 100%;
  white-space: nowrap;
}

.chart-bars {
  display: inline-flex;
  gap: 16rpx;
  padding: 0 10rpx;
}

.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  min-width: 40rpx;
}

.bar-wrapper {
  display: flex;
  gap: 8rpx;
  height: 200rpx;
  align-items: flex-end;
}

.bar-income,
.bar-expense {
  width: 20rpx;
  min-height: 4rpx;
  border-radius: 4rpx 4rpx 0 0;
  transition: height 0.3s;
}

.bar-income {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
}

.bar-expense {
  background: linear-gradient(135deg, #ff4444 0%, #ff6666 100%);
}

.bar-label {
  font-size: 20rpx;
  color: #999;
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
}

.legend-color.income {
  background: #07c160;
}

.legend-color.expense {
  background: #ff4444;
}

.legend-text {
  font-size: 22rpx;
  color: #666;
}

.chart-footer {
  text-align: center;
  padding-top: 10rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #667eea;
}

/* 账单入口 */
.bill-entry {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.bill-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.bill-icon::after {
  content: '📊';
}

.bill-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bill-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.bill-desc {
  font-size: 24rpx;
  color: #999;
}

.bill-arrow {
  font-size: 32rpx;
  color: #999;
}

/* 交易记录 */
.transactions-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.card-link {
  font-size: 24rpx;
  color: #667eea;
}

.transaction-list {
  margin-top: 20rpx;
}

.transaction-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.transaction-item:last-child {
  border-bottom: none;
}

.transaction-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f5f5f5;
}

.transaction-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.transaction-title {
  font-size: 28rpx;
  color: #333;
}

.transaction-time {
  font-size: 22rpx;
  color: #999;
}

.transaction-amount {
  font-size: 28rpx;
  font-weight: 600;
}

.transaction-amount.income {
  color: #07c160;
}

.transaction-amount.expense {
  color: #ff4444;
}

/* 空状态 */
.empty-state {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}
