<!-- pages/wallet/recharge/index.wxml -->
<view class="page">
  <!-- 余额展示 -->
  <view class="balance-section">
    <view class="balance-label">当前余额</view>
    <view class="balance-amount">¥{{wallet.balance}}</view>
  </view>

  <!-- 充值金额 -->
  <view class="section">
    <view class="section-title">选择充值金额</view>
    <view class="amount-grid">
      <view 
        class="amount-item {{selectedAmount === item.value ? 'active' : ''}}"
        wx:for="{{amountOptions}}"
        wx:key="value"
        bindtap="onAmountTap"
        data-value="{{item.value}}"
      >
        <text class="amount-value">¥{{item.value}}</text>
        <text class="amount-desc" wx:if="{{item.gift > 0}}">赠送¥{{item.gift}}</text>
      </view>
    </view>

    <!-- 自定义金额 -->
    <view class="custom-amount">
      <text class="custom-label">自定义金额</text>
      <input 
        class="custom-input" 
        type="digit"
        placeholder="请输入充值金额"
        value="{{customAmount}}"
        bindinput="onCustomAmountInput"
      />
      <text class="custom-unit">元</text>
    </view>
  </view>

  <!-- 支付方式 -->
  <view class="section">
    <view class="section-title">支付方式</view>
    <view class="payment-methods">
      <view 
        class="payment-item {{paymentMethod === 'wechat' ? 'active' : ''}}"
        bindtap="onPaymentMethodTap"
        data-method="wechat"
      >
        <image class="payment-icon" src="/images/icons/wechat-pay.png" mode="aspectFit" />
        <view class="payment-info">
          <text class="payment-name">微信支付</text>
          <text class="payment-desc">推荐使用</text>
        </view>
        <view class="payment-check">
          <text wx:if="{{paymentMethod === 'wechat'}}">✓</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 充值说明 -->
  <view class="tips">
    <view class="tip-item">• 充值金额实时到账</view>
    <view class="tip-item">• 充值成功后不可退款</view>
    <view class="tip-item">• 如有疑问请联系客服</view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="total-info">
      <text class="total-label">充值金额：</text>
      <text class="total-amount">¥{{finalAmount}}</text>
      <text class="total-gift" wx:if="{{giftAmount > 0}}">+ 赠送¥{{giftAmount}}</text>
    </view>
    <button class="btn-pay" bindtap="onPay" disabled="{{!finalAmount || paying}}">
      {{paying ? '支付中...' : '立即充值'}}
    </button>
  </view>
</view>
